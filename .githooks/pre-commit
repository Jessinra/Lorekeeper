#!/usr/bin/env bash
# Lorekeeper pre-commit hook
# Fast checks only (< 10s total) — lint, format, structural validation.
# Slow checks (mypy, unit tests, E2E) live in pre-push.
#
# Install: scripts/setup.sh  (run once per clone)

set -euo pipefail

REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

echo "🔒  Checking branch..."
bash scripts/check-branch.sh
echo "✅  branch ok"

echo ""
echo "🎫  Validating ticket format..."
bash scripts/validate-ticket.sh
echo "✅  tickets valid"

echo ""
echo "🔍  ruff check..."
uv run ruff check src tests scripts/
echo "✅  ruff passed"

echo ""
echo "🔍  biome lint (JS)..."
npx --yes @biomejs/biome lint src/lorekeeper/dashboard/static/js/
echo "✅  biome lint passed"

echo ""
echo "🔍  prettier check (JS)..."
while IFS= read -r -d '' f; do
  [ -f "$f" ] && printf '%s\0' "$f"
done < <(git ls-files -z 'src/lorekeeper/dashboard/static/js/**/*.js') | xargs -0 npx --yes prettier@3.5.3 --check
echo "✅  prettier JS passed"

echo ""
echo "🔍  prettier check (Markdown)..."
while IFS= read -r -d '' f; do
  [ -f "$f" ] && printf '%s\0' "$f"
done < <(git ls-files -z '*.md') | xargs -0 npx --yes prettier@3.5.3 --check
echo "✅  prettier markdown passed"

echo ""
echo "🔍  MCP tool documentation check..."
uv run python scripts/check_mcp_docs.py
echo "✅  mcp docs ok"

echo ""
echo "🔍  Skill format check..."
uv run python scripts/check_skills.py
echo "✅  skills ok"

echo ""
echo "✅  All checks passed — proceeding with commit"
echo "   (mypy, unit tests, E2E run on pre-push)"
