#!/usr/bin/env bash
# Lorekeeper pre-commit hook
# 1. Blocks commits on main (branch guard)
# 2. Runs lint and tests before every commit. Blocks on failure.
#
# Install: scripts/lorekeeper-setup.sh  (run once per clone)
# Bypass (emergency only): git commit --no-verify

set -euo pipefail

REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

echo "🔒  Checking branch..."
BRANCH=$(git rev-parse --abbrev-ref HEAD)
if [ "$BRANCH" = "main" ]; then
    echo "🚫  ERROR: Direct commits to 'main' are not allowed."
    echo "    Use a feature branch and open a PR instead."
    echo "    PM branch for backlog management: git checkout chore/backlog"
    exit 1
fi
echo "✅  branch ok ($BRANCH)"

echo ""
echo "🎫  Validating ticket format..."
bash scripts/validate-ticket.sh
echo "✅  tickets valid"

echo ""
echo "🔍  ruff check..."
uv run ruff check src tests
echo "✅  ruff passed"

echo ""
echo "🔍  biome check (JS)..."
npx --yes @biomejs/biome check src/lorekeeper/dashboard/static/js/
echo "✅  biome passed"

echo ""
echo "🧪  pytest..."
uv run pytest tests/ -q --tb=short
echo "✅  tests passed"

echo ""
echo "✅  All checks passed — proceeding with commit"
