{
	"$schema": "https://json.schemastore.org/prettierrc",
	"printWidth": 100,
	"useTabs": true,
	"tabWidth": 4,
	"semi": true,
	"singleQuote": false,
	"trailingComma": "all",
	"bracketSpacing": true,
	"arrowParens": "always",
	"overrides": [
		{
			"files": "*.md",
			"options": {
				"printWidth": 100,
				"proseWrap": "preserve",
				"useTabs": false,
				"tabWidth": 2
			}
		}
	]
}