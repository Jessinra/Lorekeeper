{
  "extends": ["stylelint-config-standard"],
  "customSyntax": "postcss-html",
  "rules": {
    "color-no-invalid-hex": true,
    "color-named": "never",
    "color-function-notation": null,
    "color-function-alias-notation": null,
    "alpha-value-notation": null,

    "declaration-property-value-disallowed-list": {
      "/^font-size/": ["/^[0-9]+(px|rem|em)$/"],
      "/^font-weight/": ["/^[0-9]+$/"],

      "/^color/": ["/^#[0-9a-fA-F]{3,8}$/", "/^rgba?\\(/", "/^hsla?\\(/"],
      "/^background(-color)?/": ["/^#[0-9a-fA-F]{3,8}$/"],
      "/^border(-color|-top-color|-bottom-color|-left-color|-right-color)?/": ["/^#[0-9a-fA-F]{3,8}$/"],
      "/^fill/": ["/^#[0-9a-fA-F]{3,8}$/"],
      "/^stroke/": ["/^#[0-9a-fA-F]{3,8}$/"],

      "/^padding/": ["/^[0-9]+(px|rem)$/"],
      "/^margin/": ["/^[0-9]+(px|rem)$/"],
      "/^gap/": ["/^[0-9]+(px|rem)$/"],
      "row-gap": ["/^[0-9]+(px|rem)$/"],
      "column-gap": ["/^[0-9]+(px|rem)$/"],

      "/^border-radius/": ["/^[0-9]+(px|rem)$/"]
    },

    "declaration-empty-line-before": null,
    "no-duplicate-selectors": true,
    "shorthand-property-no-redundant-values": true,
    "no-descending-specificity": null,
    "rule-empty-line-before": null,
    "selector-pseudo-class-no-unknown": [true, { "ignorePseudoClasses": ["global", "local"] }]
  },
  "ignoreFiles": ["**/*.ts", "**/*.js", "**/*.json", "node_modules/**"]
}
